# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://helpdesk_user:HelpDesk@2024!@localhost:5432/helpdesk_db

# ── JWT ─────────────────────────────────────────────────────────────────────
# ⚠ Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-longa-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Anthropic IA ─────────────────────────────────────────────────────────────
# ⚠ Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Aplicação ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production

# ⚠ Coloque o IP ou domínio do servidor (usado nos links de e-mail)
FRONTEND_URL=http://IP_DO_SERVIDOR
BASE_URL=http://IP_DO_SERVIDOR

# Nome da empresa — aparece nos e-mails e no portal
COMPANY_NAME=Minha Empresa

# ── E-mail ─────────────────────────────────────────────────────────────────────
# Deixe SMTP_USER em branco para desativar envio de e-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ti@empresa.com
SMTP_PASSWORD=senha_app_gmail
EMAIL_FROM=TI HelpDesk <ti@empresa.com>

# E-mail da fila de TI (recebe notificações de novos chamados)
TEAM_EMAIL=fila-ti@empresa.com

# ── Microsoft Teams (opcional) ────────────────────────────────────────────────
# URL do Incoming Webhook do canal de TI no Teams
# Obtenha em: Teams → Canal → Conectores → Incoming Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
